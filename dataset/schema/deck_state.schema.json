{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/deck_state.schema.json",
  "title": "DeckState",
  "type": "object",
  "required": [
    "deck_id",
    "language",
    "slides"
  ],
  "properties": {
    "deck_id": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "enum": [
        "de",
        "en"
      ]
    },
    "template": {
      "type": "string"
    },
    "agenda": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "no",
          "title",
          "layout"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "no": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string"
          },
          "layout": {
            "type": "string",
            "enum": [
              "TitleOnly",
              "TitleBullets",
              "SplitLeftImage",
              "SplitRightImage",
              "FullImage",
              "TwoColumn",
              "Quote"
            ]
          },
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "type"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "text",
                    "bullets",
                    "numbered"
                  ]
                },
                "text": {
                  "type": "string"
                },
                "items": {
                  "type": "array",
                  "minItems": 3,
                  "maxItems": 7,
                  "items": {
                    "type": "string"
                  }
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "text"
                      }
                    }
                  },
                  "then": {
                    "required": [
                      "text"
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "enum": [
                          "bullets",
                          "numbered"
                        ]
                      }
                    }
                  },
                  "then": {
                    "required": [
                      "items"
                    ]
                  }
                }
              ],
              "additionalProperties": false
            }
          },
          "image": {
            "type": "object",
            "properties": {
              "prompt": {
                "type": "string"
              },
              "size": {
                "type": "string",
                "enum": [
                  "512x768",
                  "768x512"
                ]
              },
              "url": {
                "type": "string"
              },
              "alt": {
                "type": "string"
              }
            },
            "required": [
              "prompt",
              "size"
            ],
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "mix_counts": {
      "type": "object",
      "properties": {
        "text_only": {
          "type": "integer",
          "minimum": 0
        },
        "text_image": {
          "type": "integer",
          "minimum": 0
        },
        "image_only": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "slide_index": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "no",
          "title"
        ],
        "properties": {
          "no": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}